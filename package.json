{
  "name": "kalyan-smart-student-system",
  "productName": "Kalyan Smart Student System",
  "version": "1.0.0",
  "description": "Smart Student Management System for Kalyan College",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "education",
    "management",
    "electron"
  ],
  "author": "Kalyan College",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.kalyancollege.smartstudent",
    "productName": "Kalyan Smart Student System",
    "copyright": "Copyright © 2026 Kalyan College",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!installer/**",
      "!.github/**",
      "!.git/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "media/kalyan_college_logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "media/kalyan_college_logo.ico",
      "uninstallerIcon": "media/kalyan_college_logo.ico",
      "installerHeaderIcon": "media/kalyan_college_logo.ico",
      "include": "installer/installer.nsh",
      "perMachine": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kalyan Smart Student System",
      "installerSidebar": null,
      "license": null
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "multicast-dns": "^7.2.5",
    "node-machine-id": "^1.1.12"
  }
}
